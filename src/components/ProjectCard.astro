---
// src/components/ProjectCard.astro
interface Project {
  name: string;
  description: string;
  tech: string[];
  repo?: string;
  live?: string;
  image?: string;
}

const { project } = Astro.props as { project: Project };
---

<article
  class="group relative rounded-3xl overflow-hidden
         bg-gradient-to-br from-white to-slate-50
         dark:from-zinc-900 dark:to-zinc-900/50
         border border-slate-200/60 dark:border-zinc-800/60
         shadow-lg hover:shadow-2xl
         transition-all duration-500 ease-out
         hover:-translate-y-2 hover:scale-[1.02]
         flex flex-col h-full"
>
  <!-- Animated gradient overlay -->
  <div
    class="absolute inset-0 opacity-0 group-hover:opacity-100
           bg-gradient-to-br from-indigo-500/5 via-purple-500/5 to-pink-500/5
           dark:from-indigo-500/10 dark:via-purple-500/10 dark:to-pink-500/10
           transition-opacity duration-500 pointer-events-none"
    aria-hidden="true"
  ></div>

  <!-- Image Container with Overlay -->
  {project.image && (
    <div class="relative h-52 overflow-hidden bg-slate-100 dark:bg-zinc-800">
      <img
        src={project.image}
        alt={project.name}
        class="w-full h-full object-cover transition-transform duration-700 
               group-hover:scale-110 group-hover:rotate-1"
        loading="lazy"
        decoding="async"
      />
      
      <!-- Gradient overlay on image -->
      <div
        class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-slate-900/20 to-transparent
               dark:from-zinc-950/80 dark:via-zinc-950/40 dark:to-transparent
               opacity-60 group-hover:opacity-40 transition-opacity duration-500"
        aria-hidden="true"
      ></div>

      <!-- Floating tech badges on image -->
      <div class="absolute bottom-3 left-3 right-3 flex flex-wrap gap-1.5">
        {project.tech.slice(0, 3).map((t) => (
          <span
            class="text-xs font-medium px-2.5 py-1 rounded-full
                   bg-white/90 dark:bg-zinc-900/90 backdrop-blur-sm
                   text-slate-700 dark:text-zinc-300
                   border border-slate-200/50 dark:border-zinc-700/50
                   shadow-sm"
          >
            {t}
          </span>
        ))}
        {project.tech.length > 3 && (
          <span
            class="text-xs font-medium px-2.5 py-1 rounded-full
                   bg-white/90 dark:bg-zinc-900/90 backdrop-blur-sm
                   text-slate-500 dark:text-zinc-400
                   border border-slate-200/50 dark:border-zinc-700/50
                   shadow-sm"
          >
            +{project.tech.length - 3}
          </span>
        )}
      </div>
    </div>
  )}

  <!-- Content -->
  <div class="relative p-6 flex flex-col flex-grow">
    <!-- Project Name with Gradient Underline -->
    <h3 class="text-xl font-bold text-slate-900 dark:text-zinc-100 mb-3 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors duration-300">
      {project.name}
      <span
        class="block h-0.5 w-0 group-hover:w-full bg-gradient-to-r from-indigo-500 to-purple-500 transition-all duration-500 mt-1.5 rounded-full"
        aria-hidden="true"
      ></span>
    </h3>

    <!-- Description -->
    <p class="text-sm text-slate-600 dark:text-zinc-400 leading-relaxed flex-grow mb-4">
      {project.description}
    </p>

    <!-- Action Links -->
    <div class="flex items-center gap-3 pt-4 border-t border-slate-200/60 dark:border-zinc-800/60">
      {project.live && (
        <a
          href={project.live}
          target="_blank"
          rel="noreferrer"
          class="group/link inline-flex items-center gap-2 px-4 py-2 rounded-xl
                 bg-gradient-to-r from-indigo-600 to-purple-600
                 hover:from-indigo-500 hover:to-purple-500
                 dark:from-indigo-500 dark:to-purple-500
                 dark:hover:from-indigo-400 dark:hover:to-purple-400
                 text-white text-sm font-medium
                 shadow-md hover:shadow-lg
                 transition-all duration-300
                 hover:scale-105 active:scale-95"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/>
          </svg>
          Live Demo
        </a>
      )}
      
      {project.repo && (
        <a
          href={project.repo}
          target="_blank"
          rel="noreferrer"
          class="group/link inline-flex items-center gap-2 px-4 py-2 rounded-xl
                 border-2 border-slate-300 dark:border-zinc-700
                 hover:border-slate-400 dark:hover:border-zinc-600
                 bg-white/50 dark:bg-zinc-900/50
                 text-slate-700 dark:text-zinc-300
                 text-sm font-medium
                 transition-all duration-300
                 hover:scale-105 active:scale-95
                 hover:shadow-md"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .5a11.5 11.5 0 0 0-3.64 22.4c.58.1.8-.25.8-.56v-2c-3.26.71-3.95-1.57-3.95-1.57-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.8 2.72 1.28 3.38.98.1-.76.41-1.28.75-1.58-2.6-.29-5.34-1.3-5.34-5.8 0-1.28.46-2.33 1.2-3.15-.12-.3-.52-1.52.12-3.17 0 0 .98-.31 3.2 1.2a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.2 3.2-1.2.64 1.65.24 2.87.12 3.17.75.82 1.2 1.87 1.2 3.15 0 4.5-2.75 5.51-5.36 5.8.43.37.81 1.1.81 2.22v3.3c0 .31.21.67.81.56A11.5 11.5 0 0 0 12 .5z"/>
          </svg>
          Repository
        </a>
      )}
    </div>
  </div>

  <!-- Decorative corner accent -->
  <div
    class="absolute top-0 right-0 w-24 h-24 
           bg-gradient-to-br from-indigo-500/10 to-purple-500/10
           dark:from-indigo-500/20 dark:to-purple-500/20
           rounded-bl-[3rem] opacity-0 group-hover:opacity-100
           transition-opacity duration-500 pointer-events-none"
    aria-hidden="true"
  ></div>
</article>
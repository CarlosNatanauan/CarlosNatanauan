---
// src/components/ProjectCard.astro
interface Project {
  name: string;
  description: string;
  tech: string[];
  repo?: string;
  live?: string;
  demo?: string;
  tryIt?: string;
  image?: string;
  featured?: boolean;
}

const { project } = Astro.props as { project: Project };
const f = project.featured;
---

<!-- Gradient border wrapper for featured, transparent pass-through otherwise -->
<div class={`h-full${f ? ' p-[2px] rounded-3xl bg-gradient-to-br from-violet-500 via-purple-500 to-indigo-500 shadow-[0_0_48px_rgba(139,92,246,0.22)] dark:shadow-[0_0_56px_rgba(139,92,246,0.38)]' : ''}`}>
  <article
    class={`group relative rounded-3xl overflow-hidden
           bg-gradient-to-br from-white to-slate-50
           dark:from-zinc-900 dark:to-zinc-900/50
           ${f ? 'border-0' : 'border border-slate-200/60 dark:border-zinc-800/60'}
           shadow-lg hover:shadow-2xl
           transition-all duration-500 ease-out
           hover:-translate-y-1 hover:scale-[1.01]
           ${f ? 'flex flex-col md:flex-row' : 'flex flex-col'} h-full`}
  >
    <!-- Animated gradient overlay -->
    <div
      class="absolute inset-0 opacity-0 group-hover:opacity-100
             bg-gradient-to-br from-indigo-500/5 via-purple-500/5 to-pink-500/5
             dark:from-indigo-500/10 dark:via-purple-500/10 dark:to-pink-500/10
             transition-opacity duration-500 pointer-events-none"
      aria-hidden="true"
    ></div>

    <!-- Image Container -->
    {project.image && (
      <div class={`relative overflow-hidden bg-slate-100 dark:bg-zinc-800 flex-shrink-0
                   ${f ? 'h-64 md:h-auto md:w-2/5' : 'h-52'}`}>
        <img
          src={project.image}
          alt={project.name}
          class="w-full h-full object-cover transition-transform duration-700
                 group-hover:scale-110 group-hover:rotate-1"
          loading="lazy"
          decoding="async"
        />

        <!-- Gradient overlay on image -->
        <div
          class={`absolute inset-0 opacity-60 group-hover:opacity-40 transition-opacity duration-500
                  ${f
                    ? 'bg-gradient-to-t md:bg-gradient-to-r from-slate-900/70 via-slate-900/20 to-transparent dark:from-zinc-950/80 dark:via-zinc-950/40 dark:to-transparent'
                    : 'bg-gradient-to-t from-slate-900/60 via-slate-900/20 to-transparent dark:from-zinc-950/80 dark:via-zinc-950/40 dark:to-transparent'}`}
          aria-hidden="true"
        ></div>

        <!-- "New" badge — featured only -->
        {f && (
          <div class="absolute top-3 right-3 z-10 inline-flex items-center gap-1
                      px-3 py-1 rounded-full
                      bg-white/95 dark:bg-zinc-900/95 backdrop-blur-sm
                      border border-violet-300/60 dark:border-violet-600/60
                      shadow-md">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-violet-500 dark:text-violet-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
            </svg>
            <span class="text-xs font-bold text-violet-600 dark:text-violet-400 tracking-wide">New</span>
          </div>
        )}

        <!-- Floating tech badges on image -->
        <div class="absolute bottom-3 left-3 right-3 flex flex-wrap gap-1.5">
          {project.tech.slice(0, f ? 4 : 3).map((t) => (
            <span
              class="text-xs font-medium px-2.5 py-1 rounded-full
                     bg-white/90 dark:bg-zinc-900/90 backdrop-blur-sm
                     text-slate-700 dark:text-zinc-300
                     border border-slate-200/50 dark:border-zinc-700/50
                     shadow-sm"
            >
              {t}
            </span>
          ))}
          {project.tech.length > (f ? 4 : 3) && (
            <span
              class="text-xs font-medium px-2.5 py-1 rounded-full
                     bg-white/90 dark:bg-zinc-900/90 backdrop-blur-sm
                     text-slate-500 dark:text-zinc-400
                     border border-slate-200/50 dark:border-zinc-700/50
                     shadow-sm"
            >
              +{project.tech.length - (f ? 4 : 3)}
            </span>
          )}
        </div>
      </div>
    )}

    <!-- Content -->
    <div class="relative p-6 flex flex-col flex-grow">
      <!-- Featured label above title -->
      {f && (
        <p class="text-xs font-semibold uppercase tracking-widest text-violet-500 dark:text-violet-400 mb-2">
          Featured Project
        </p>
      )}

      <!-- Project Name -->
      <h3 class={`font-bold text-slate-900 dark:text-zinc-100 mb-3
                  group-hover:text-indigo-600 dark:group-hover:text-indigo-400
                  transition-colors duration-300
                  ${f ? 'text-2xl' : 'text-xl'}`}>
        {project.name}
        <span
          class="block h-0.5 w-0 group-hover:w-full bg-gradient-to-r from-indigo-500 to-purple-500 transition-all duration-500 mt-1.5 rounded-full"
          aria-hidden="true"
        ></span>
      </h3>

      <!-- Description -->
      <p class={`text-slate-600 dark:text-zinc-400 leading-relaxed flex-grow mb-4
                 ${f ? 'text-sm md:text-base' : 'text-sm'}`}>
        {project.description}
      </p>

      <!-- Action Links -->
      <div class="flex flex-wrap items-center gap-2 pt-4 border-t border-slate-200/60 dark:border-zinc-800/60">
        {project.tryIt && (
          <a
            href={project.tryIt}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
                   bg-emerald-500 hover:bg-emerald-400
                   dark:bg-emerald-600 dark:hover:bg-emerald-500
                   text-white text-xs font-semibold
                   shadow-sm hover:shadow-md
                   transition-all duration-200
                   hover:scale-105 active:scale-95"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2a10 10 0 1 1 0 20A10 10 0 0 1 12 2zm-2 6v8l6-4-6-4z"/>
            </svg>
            Try It
          </a>
        )}

        {project.live && (
          <a
            href={project.live}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
                   bg-indigo-500 hover:bg-indigo-400
                   dark:bg-indigo-600 dark:hover:bg-indigo-500
                   text-white text-xs font-semibold
                   shadow-sm hover:shadow-md
                   transition-all duration-200
                   hover:scale-105 active:scale-95"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/>
            </svg>
            Live Demo
          </a>
        )}

        {project.demo && (
          <a
            href={project.demo}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
                   bg-rose-500 hover:bg-rose-400
                   dark:bg-rose-600 dark:hover:bg-rose-500
                   text-white text-xs font-semibold
                   shadow-sm hover:shadow-md
                   transition-all duration-200
                   hover:scale-105 active:scale-95"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.54 3.5 12 3.5 12 3.5s-7.54 0-9.38.55A3.02 3.02 0 0 0 .5 6.19C0 8.04 0 12 0 12s0 3.96.5 5.81a3.02 3.02 0 0 0 2.12 2.14C4.46 20.5 12 20.5 12 20.5s7.54 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14C24 15.96 24 12 24 12s0-3.96-.5-5.81zM9.75 15.5v-7l6.5 3.5-6.5 3.5z"/>
            </svg>
            Demo Video
          </a>
        )}

        {project.repo && (
          <a
            href={project.repo}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
                   border border-slate-300 dark:border-zinc-600
                   bg-slate-100/80 hover:bg-slate-200/80
                   dark:bg-zinc-800/80 dark:hover:bg-zinc-700/80
                   text-slate-600 dark:text-zinc-400
                   text-xs font-semibold
                   transition-all duration-200
                   hover:scale-105 active:scale-95
                   hover:shadow-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .5a11.5 11.5 0 0 0-3.64 22.4c.58.1.8-.25.8-.56v-2c-3.26.71-3.95-1.57-3.95-1.57-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.8 2.72 1.28 3.38.98.1-.76.41-1.28.75-1.58-2.6-.29-5.34-1.3-5.34-5.8 0-1.28.46-2.33 1.2-3.15-.12-.3-.52-1.52.12-3.17 0 0 .98-.31 3.2 1.2a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.2 3.2-1.2.64 1.65.24 2.87.12 3.17.75.82 1.2 1.87 1.2 3.15 0 4.5-2.75 5.51-5.36 5.8.43.37.81 1.1.81 2.22v3.3c0 .31.21.67.81.56A11.5 11.5 0 0 0 12 .5z"/>
            </svg>
            Repository
          </a>
        )}
      </div>
    </div>

    <!-- Decorative corner accent — regular cards only -->
    {!f && (
      <div
        class="absolute top-0 right-0 w-24 h-24
               bg-gradient-to-br from-indigo-500/10 to-purple-500/10
               dark:from-indigo-500/20 dark:to-purple-500/20
               rounded-bl-[3rem] opacity-0 group-hover:opacity-100
               transition-opacity duration-500 pointer-events-none"
        aria-hidden="true"
      ></div>
    )}
  </article>
</div>

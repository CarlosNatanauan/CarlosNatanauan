---
// src/components/ProjectCard.astro
interface Project {
  name: string;
  description: string;
  tech: string[];
  repo?: string;
  live?: string;
  demo?: string;
  tryIt?: string;
  image?: string;
  imageMobile?: string;
  featured?: boolean;
}

const { project } = Astro.props as { project: Project };
const f = project.featured;
const MAX_TAGS = f ? 5 : 3;
const visibleTags = project.tech.slice(0, MAX_TAGS);
const overflow = project.tech.length - MAX_TAGS;
---

{f ? (
  <!-- ─── Featured card ─── -->
  <div class="p-[2px] rounded-3xl bg-gradient-to-br from-violet-500 via-purple-500 to-indigo-500
              shadow-[0_0_48px_rgba(139,92,246,0.22)] dark:shadow-[0_0_64px_rgba(139,92,246,0.38)] h-full">
    <article class="group relative rounded-3xl overflow-hidden h-full min-h-[18rem]
                    flex flex-col md:flex-row
                    bg-white dark:bg-zinc-800 shadow-lg">

      <!-- Image -->
      {project.image && (
        <div class="relative md:w-1/2 h-60 md:h-auto flex-shrink-0 overflow-hidden">
          {project.imageMobile && (
            <img src={project.imageMobile} alt={project.name}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 md:hidden"
              loading="lazy" decoding="async" />
          )}
          <img src={project.image} alt={project.name}
            class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-105
                   ${project.imageMobile ? 'hidden md:block' : ''}`}
            loading="lazy" decoding="async" />
          <div class="absolute inset-0 bg-gradient-to-r from-transparent to-white/60 dark:to-zinc-800/60 hidden md:block" aria-hidden="true"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-white/70 dark:from-zinc-800/70 to-transparent md:hidden" aria-hidden="true"></div>
          <!-- Featured badge -->
          <div class="absolute top-3 left-3 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
                      bg-white/90 dark:bg-zinc-800/80 backdrop-blur-sm
                      border border-violet-400/60 dark:border-violet-500/50 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-violet-500 dark:text-violet-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
            </svg>
            <span class="text-xs font-bold text-violet-500 dark:text-violet-400 tracking-wide">Featured</span>
          </div>
        </div>
      )}

      <!-- Content -->
      <div class="flex flex-col justify-between p-6 md:p-8 flex-grow">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-violet-500 dark:text-violet-400 mb-2">Featured Project</p>
          <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-3
                     group-hover:text-violet-600 dark:group-hover:text-violet-300 transition-colors duration-300">
            {project.name}
          </h3>
          <!-- Tags -->
          <div class={`relative flex items-center gap-1.5 min-w-0 overflow-hidden mb-4${overflow > 0 ? ' pr-9' : ''}`}>
            {visibleTags.map((t) => (
              <span class="shrink-0 text-xs font-medium px-2.5 py-1 rounded-full
                           bg-slate-100 dark:bg-white/10
                           text-slate-600 dark:text-zinc-300
                           border border-slate-200 dark:border-white/15
                           whitespace-nowrap max-w-[9rem] truncate" title={t}>
                {t}
              </span>
            ))}
            {overflow > 0 && (
              <span class="absolute right-0 top-1/2 -translate-y-1/2
                           text-xs font-medium px-2.5 py-1 rounded-full
                           bg-violet-100 dark:bg-violet-500/20
                           text-violet-600 dark:text-violet-300
                           border border-violet-300/60 dark:border-violet-500/30
                           whitespace-nowrap">
                +{overflow}
              </span>
            )}
          </div>
          <p class="text-slate-600 dark:text-zinc-400 text-sm leading-relaxed line-clamp-4">{project.description}</p>
        </div>

        <!-- Buttons -->
        <div class="flex items-center justify-between gap-2 mt-6 pt-5
                    border-t border-slate-200 dark:border-white/10">
          <div class="flex items-center gap-1.5 flex-wrap">
            {project.tryIt && (
              <a href={project.tryIt} target="_blank" rel="noreferrer"
                 class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
                        bg-emerald-500 hover:bg-emerald-400 text-white text-xs font-semibold
                        shadow-sm hover:shadow-md transition-all duration-200 hover:scale-105 active:scale-95">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2a10 10 0 1 1 0 20A10 10 0 0 1 12 2zm-2 6v8l6-4-6-4z"/>
                </svg>
                Try It
              </a>
            )}
            {project.live && (
              <a href={project.live} target="_blank" rel="noreferrer"
                 class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
                        bg-indigo-500 hover:bg-indigo-400 text-white text-xs font-semibold
                        shadow-sm hover:shadow-md transition-all duration-200 hover:scale-105 active:scale-95">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/>
                </svg>
                Live
              </a>
            )}
            {project.demo && (
              <a href={project.demo} target="_blank" rel="noreferrer"
                 class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
                        bg-rose-500 hover:bg-rose-400 text-white text-xs font-semibold
                        shadow-sm hover:shadow-md transition-all duration-200 hover:scale-105 active:scale-95">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.54 3.5 12 3.5 12 3.5s-7.54 0-9.38.55A3.02 3.02 0 0 0 .5 6.19C0 8.04 0 12 0 12s0 3.96.5 5.81a3.02 3.02 0 0 0 2.12 2.14C4.46 20.5 12 20.5 12 20.5s7.54 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14C24 15.96 24 12 24 12s0-3.96-.5-5.81zM9.75 15.5v-7l6.5 3.5-6.5 3.5z"/>
                </svg>
                Demo
              </a>
            )}
          </div>
          {project.repo && (
            <a href={project.repo} target="_blank" rel="noreferrer"
               class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
                      border border-slate-300 dark:border-white/20
                      bg-slate-100 hover:bg-slate-200 dark:bg-white/5 dark:hover:bg-white/10
                      text-slate-600 hover:text-slate-800 dark:text-zinc-400 dark:hover:text-zinc-200
                      text-xs font-semibold
                      transition-all duration-200 hover:scale-105 active:scale-95 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 .5a11.5 11.5 0 0 0-3.64 22.4c.58.1.8-.25.8-.56v-2c-3.26.71-3.95-1.57-3.95-1.57-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.8 2.72 1.28 3.38.98.1-.76.41-1.28.75-1.58-2.6-.29-5.34-1.3-5.34-5.8 0-1.28.46-2.33 1.2-3.15-.12-.3-.52-1.52.12-3.17 0 0 .98-.31 3.2 1.2a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.2 3.2-1.2.64 1.65.24 2.87.12 3.17.75.82 1.2 1.87 1.2 3.15 0 4.5-2.75 5.51-5.36 5.8.43.37.81 1.1.81 2.22v3.3c0 .31.21.67.81.56A11.5 11.5 0 0 0 12 .5z"/>
              </svg>
              Repo
            </a>
          )}
        </div>
      </div>
    </article>
  </div>
) : (
  <!-- ─── Regular card ─── -->
  <!-- Mobile: stacked (image top, content below) | sm+: fixed-height overlay -->
  <article class="group relative rounded-2xl overflow-hidden shadow-lg
                  border border-slate-200/60 dark:border-white/5
                  hover:shadow-2xl hover:-translate-y-1
                  transition-all duration-500 ease-out
                  sm:h-64">

    <!-- Image: block on mobile, absolute full-fill on sm+ -->
    <div class="relative h-40 sm:h-full sm:absolute sm:inset-0 overflow-hidden flex-shrink-0">
      {project.image ? (
        <img
          src={project.image}
          alt={project.name}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-indigo-900 to-zinc-900"></div>
      )}
      <!-- sm+ gradient -->
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/40 to-zinc-950/5 hidden sm:block" aria-hidden="true"></div>
    </div>

    <!-- ── Mobile content (below image) ── -->
    <div class="sm:hidden bg-white dark:bg-zinc-900 p-4 flex flex-col gap-3
                border-t border-slate-200 dark:border-white/5">
      <!-- Tags -->
      <div class={`relative flex items-center gap-1.5 min-w-0 overflow-hidden${overflow > 0 ? ' pr-9' : ''}`}>
        {visibleTags.map((t) => (
          <span class="shrink-0 text-xs font-medium px-2 py-0.5 rounded-full
                       bg-slate-100 dark:bg-white/10
                       text-slate-600 dark:text-zinc-300
                       border border-slate-200 dark:border-white/15
                       whitespace-nowrap max-w-[8rem] truncate" title={t}>
            {t}
          </span>
        ))}
        {overflow > 0 && (
          <span class="absolute right-0 top-1/2 -translate-y-1/2
                       text-xs font-medium px-2 py-0.5 rounded-full
                       bg-indigo-50 dark:bg-indigo-500/25
                       text-indigo-600 dark:text-indigo-300
                       border border-indigo-200 dark:border-indigo-400/30
                       whitespace-nowrap">
            +{overflow}
          </span>
        )}
      </div>
      <!-- Name + description -->
      <div>
        <h3 class="text-slate-900 dark:text-white font-bold text-base leading-snug mb-1">{project.name}</h3>
        <p class="text-slate-600 dark:text-zinc-400 text-xs leading-relaxed line-clamp-2">{project.description}</p>
      </div>
      <!-- Buttons -->
      <div class="flex items-center justify-between gap-2">
        <div class="flex items-center gap-1.5 flex-wrap">
          {project.tryIt && (
            <a href={project.tryIt} target="_blank" rel="noreferrer"
               class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                      bg-emerald-500 hover:bg-emerald-400 text-white text-xs font-semibold
                      transition-all duration-200 active:scale-95">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 1 1 0 20A10 10 0 0 1 12 2zm-2 6v8l6-4-6-4z"/></svg>
              Try It
            </a>
          )}
          {project.demo && (
            <a href={project.demo} target="_blank" rel="noreferrer"
               class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                      bg-rose-500 hover:bg-rose-400 text-white text-xs font-semibold
                      transition-all duration-200 active:scale-95">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.54 3.5 12 3.5 12 3.5s-7.54 0-9.38.55A3.02 3.02 0 0 0 .5 6.19C0 8.04 0 12 0 12s0 3.96.5 5.81a3.02 3.02 0 0 0 2.12 2.14C4.46 20.5 12 20.5 12 20.5s7.54 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14C24 15.96 24 12 24 12s0-3.96-.5-5.81zM9.75 15.5v-7l6.5 3.5-6.5 3.5z"/></svg>
              Demo
            </a>
          )}
          {project.live && (
            <a href={project.live} target="_blank" rel="noreferrer"
               class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                      bg-indigo-500 hover:bg-indigo-400 text-white text-xs font-semibold
                      transition-all duration-200 active:scale-95">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/></svg>
              Live
            </a>
          )}
        </div>
        {project.repo && (
          <a href={project.repo} target="_blank" rel="noreferrer"
             class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                    border border-slate-300 dark:border-white/20
                    bg-slate-100 hover:bg-slate-200 dark:bg-white/5 dark:hover:bg-white/10
                    text-slate-600 dark:text-zinc-400 text-xs font-semibold
                    transition-all duration-200 active:scale-95 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5a11.5 11.5 0 0 0-3.64 22.4c.58.1.8-.25.8-.56v-2c-3.26.71-3.95-1.57-3.95-1.57-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.8 2.72 1.28 3.38.98.1-.76.41-1.28.75-1.58-2.6-.29-5.34-1.3-5.34-5.8 0-1.28.46-2.33 1.2-3.15-.12-.3-.52-1.52.12-3.17 0 0 .98-.31 3.2 1.2a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.2 3.2-1.2.64 1.65.24 2.87.12 3.17.75.82 1.2 1.87 1.2 3.15 0 4.5-2.75 5.51-5.36 5.8.43.37.81 1.1.81 2.22v3.3c0 .31.21.67.81.56A11.5 11.5 0 0 0 12 .5z"/></svg>
            Repo
          </a>
        )}
      </div>
    </div>

    <!-- ── sm+: Default state (title + tags at bottom) ── -->
    <div class="absolute inset-0
                bg-gradient-to-t from-zinc-900/80 via-zinc-900/20 to-transparent
                hidden sm:flex flex-col justify-end p-4
                group-hover:opacity-0 transition-opacity duration-300">
      <h3 class="text-white font-bold text-base leading-snug mb-2">{project.name}</h3>
      <div class={`relative flex items-center gap-1.5 min-w-0 overflow-hidden${overflow > 0 ? ' pr-9' : ''}`}>
        {visibleTags.map((t) => (
          <span class="shrink-0 text-xs font-medium px-2 py-0.5 rounded-full
                       bg-white/15 text-zinc-200 border border-white/20
                       whitespace-nowrap max-w-[8rem] truncate" title={t}>
            {t}
          </span>
        ))}
        {overflow > 0 && (
          <span class="absolute right-0 top-1/2 -translate-y-1/2
                       text-xs font-medium px-2 py-0.5 rounded-full
                       bg-indigo-500/30 text-indigo-300 border border-indigo-500/30
                       whitespace-nowrap">
            +{overflow}
          </span>
        )}
      </div>
    </div>

    <!-- ── sm+: Hover state (full content) ── -->
    <div class="absolute inset-0
                bg-white/95 dark:bg-zinc-950/92 backdrop-blur-[2px]
                hidden sm:flex flex-col justify-between p-4
                opacity-0 group-hover:opacity-100
                transition-opacity duration-300">
      <!-- Top: tags -->
      <div class={`relative flex items-center gap-1.5 min-w-0 overflow-hidden${overflow > 0 ? ' pr-9' : ''}`}>
        {visibleTags.map((t) => (
          <span class="shrink-0 text-xs font-medium px-2 py-0.5 rounded-full
                       bg-slate-100 dark:bg-white/10
                       text-slate-600 dark:text-zinc-300
                       border border-slate-200 dark:border-white/15
                       whitespace-nowrap max-w-[8rem] truncate" title={t}>
            {t}
          </span>
        ))}
        {overflow > 0 && (
          <span class="absolute right-0 top-1/2 -translate-y-1/2
                       text-xs font-medium px-2 py-0.5 rounded-full
                       bg-indigo-50 dark:bg-indigo-500/25
                       text-indigo-600 dark:text-indigo-300
                       border border-indigo-200 dark:border-indigo-400/30
                       whitespace-nowrap">
            +{overflow}
          </span>
        )}
      </div>
      <!-- Middle: name + description -->
      <div>
        <h3 class="text-slate-900 dark:text-white font-bold text-base leading-snug mb-1.5">{project.name}</h3>
        <p class="text-slate-600 dark:text-zinc-400 text-xs leading-relaxed line-clamp-4">{project.description}</p>
      </div>
      <!-- Bottom: CTAs left, Repo right -->
      <div class="flex items-center justify-between gap-2">
        <div class="flex items-center gap-1.5 flex-wrap">
          {project.tryIt && (
            <a href={project.tryIt} target="_blank" rel="noreferrer"
               class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                      bg-emerald-500 hover:bg-emerald-400 text-white text-xs font-semibold
                      transition-all duration-200 hover:scale-105 active:scale-95">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2a10 10 0 1 1 0 20A10 10 0 0 1 12 2zm-2 6v8l6-4-6-4z"/>
              </svg>
              Try It
            </a>
          )}
          {project.live && (
            <a href={project.live} target="_blank" rel="noreferrer"
               class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                      bg-indigo-500 hover:bg-indigo-400 text-white text-xs font-semibold
                      transition-all duration-200 hover:scale-105 active:scale-95">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/>
              </svg>
              Live
            </a>
          )}
          {project.demo && (
            <a href={project.demo} target="_blank" rel="noreferrer"
               class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                      bg-rose-500 hover:bg-rose-400 text-white text-xs font-semibold
                      transition-all duration-200 hover:scale-105 active:scale-95">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.54 3.5 12 3.5 12 3.5s-7.54 0-9.38.55A3.02 3.02 0 0 0 .5 6.19C0 8.04 0 12 0 12s0 3.96.5 5.81a3.02 3.02 0 0 0 2.12 2.14C4.46 20.5 12 20.5 12 20.5s7.54 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14C24 15.96 24 12 24 12s0-3.96-.5-5.81zM9.75 15.5v-7l6.5 3.5-6.5 3.5z"/>
              </svg>
              Demo
            </a>
          )}
        </div>
        {project.repo && (
          <a href={project.repo} target="_blank" rel="noreferrer"
             class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                    border border-slate-300 dark:border-white/20
                    bg-slate-100 hover:bg-slate-200 dark:bg-white/5 dark:hover:bg-white/15
                    text-slate-600 dark:text-zinc-400 text-xs font-semibold
                    transition-all duration-200 hover:scale-105 active:scale-95 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .5a11.5 11.5 0 0 0-3.64 22.4c.58.1.8-.25.8-.56v-2c-3.26.71-3.95-1.57-3.95-1.57-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.8 2.72 1.28 3.38.98.1-.76.41-1.28.75-1.58-2.6-.29-5.34-1.3-5.34-5.8 0-1.28.46-2.33 1.2-3.15-.12-.3-.52-1.52.12-3.17 0 0 .98-.31 3.2 1.2a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.2 3.2-1.2.64 1.65.24 2.87.12 3.17.75.82 1.2 1.87 1.2 3.15 0 4.5-2.75 5.51-5.36 5.8.43.37.81 1.1.81 2.22v3.3c0 .31.21.67.81.56A11.5 11.5 0 0 0 12 .5z"/>
            </svg>
            Repo
          </a>
        )}
      </div>
    </div>
  </article>
)}

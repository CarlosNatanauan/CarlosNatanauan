---
// src/components/ExperienceItem.astro
interface Experience {
  role: string;
  company: string;
  period: string;
  bullets: string[];
  companyUrl?: string;
  datetime?: string;
}

const { item } = Astro.props as { item: Experience };
const CompanyTag = item.companyUrl ? 'a' : 'span';
const companyAttrs = item.companyUrl ? { href: item.companyUrl, target: '_blank', rel: 'noreferrer' } : {};
const isPresent = item.period.toLowerCase().includes("present");
---

<article class="group relative rounded-2xl
                bg-white/70 dark:bg-zinc-900/40
                backdrop-blur-md
                border border-slate-200/60 dark:border-white/10
                border-l-[3px] border-l-indigo-500
                shadow-sm hover:shadow-[0_8px_32px_rgba(99,102,241,0.15)] hover:-translate-y-0.5
                transition-all duration-300 ease-out
                p-6">

  <!-- Header row: role + date/badge -->
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">

    <!-- Role -->
    <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-zinc-100 leading-snug">
      {item.role}
    </h3>

    <!-- Date + Current -->
    <div class="flex items-center gap-2 shrink-0">
      <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full
                  bg-slate-100/80 dark:bg-white/5
                  border border-slate-200/60 dark:border-white/10
                  text-xs font-medium text-slate-600 dark:text-zinc-400
                  whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <path d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
        <time {...(item.datetime ? { datetime: item.datetime } : {})}>
          {item.period}
        </time>
      </div>

      {isPresent && (
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full
                     text-xs font-semibold
                     bg-emerald-500 dark:bg-emerald-500
                     text-white
                     shadow-sm animate-pulse-slow whitespace-nowrap">
          <span class="relative flex h-1.5 w-1.5 shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white/70"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white"></span>
          </span>
          Current
        </span>
      )}
    </div>
  </div>

  <!-- Company -->
  <CompanyTag
    class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors mb-5 group/company"
    {...companyAttrs}
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      <path d="M9 22V12h6v10"/>
    </svg>
    <span class="group-hover/company:underline underline-offset-4">{item.company}</span>
    {item.companyUrl && (
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0 opacity-0 group-hover/company:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/>
      </svg>
    )}
  </CompanyTag>

  <!-- Divider -->
  <div class="border-t border-slate-100/80 dark:border-white/10 mb-4"></div>

  <!-- Bullets -->
  {item.bullets?.length > 0 && (
    <ul class="space-y-3">
      {item.bullets.map((b) => (
        <li class="flex items-start gap-3">
          <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center
                       rounded-full bg-indigo-50 dark:bg-indigo-950/50
                       border border-indigo-200/60 dark:border-indigo-800/60"
                aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-indigo-500 dark:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <path d="M5 12l5 5L20 7"/>
            </svg>
          </span>
          <span class="text-sm leading-relaxed text-slate-600 dark:text-zinc-400">{b}</span>
        </li>
      ))}
    </ul>
  )}
</article>

---
// src/components/ExperienceItem.astro
interface Experience {
  role: string;
  company: string;
  period: string;
  bullets: string[];
  companyUrl?: string;
  datetime?: string;
}

const { item } = Astro.props as { item: Experience };
const CompanyTag = item.companyUrl ? 'a' : 'span';
const companyAttrs = item.companyUrl ? { href: item.companyUrl, target: '_blank', rel: 'noreferrer' } : {};

// detect if current job
const isPresent = item.period.toLowerCase().includes("present");
---

<article class="group relative rounded-3xl overflow-hidden bg-gradient-to-br from-white to-slate-50 dark:from-zinc-900 dark:to-zinc-900/50 border border-slate-200/60 dark:border-zinc-800/60 shadow-lg hover:shadow-2xl transition-all duration-500 ease-out hover:-translate-y-1">
  <!-- Animated gradient overlay -->
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-gradient-to-br from-indigo-500/5 via-purple-500/5 to-pink-500/5 dark:from-indigo-500/10 dark:via-purple-500/10 dark:to-pink-500/10 transition-opacity duration-500 pointer-events-none" aria-hidden="true"></div>

  <!-- Decorative gradient rail -->
  <div aria-hidden="true" class="absolute left-0 top-0 h-full w-1.5 bg-gradient-to-b from-indigo-500 via-purple-500 to-pink-500 opacity-60 group-hover:opacity-100 group-hover:w-2 transition-all duration-500"></div>

  <div class="relative p-6 lg:p-8">
    <!-- Header - Better layout for all screen sizes -->
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
      <div class="flex-1 min-w-0">
        <!-- Role -->
        <h3 class="text-xl lg:text-2xl font-bold text-slate-900 dark:text-zinc-100 leading-tight mb-3">
          {item.role}
          <span class="block h-0.5 w-0 group-hover:w-20 bg-gradient-to-r from-indigo-500 to-purple-500 transition-all duration-500 mt-2 rounded-full" aria-hidden="true"></span>
        </h3>
        
        <!-- Company -->
        <CompanyTag class="inline-flex items-center gap-2 text-base lg:text-lg font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors group/company" {...companyAttrs}>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 lg:h-5 lg:w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <path d="M9 22V12h6v10"/>
          </svg>
          <span class="underline-offset-4 group-hover/company:underline break-words">
            {item.company}
          </span>
          {item.companyUrl && (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 lg:h-4 lg:w-4 shrink-0 opacity-0 group-hover/company:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/>
            </svg>
          )}
        </CompanyTag>
      </div>

      <!-- Period Badge - Better positioned -->
      <div class="flex items-center gap-3 shrink-0">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 dark:bg-zinc-800 border border-slate-200 dark:border-zinc-700 text-sm font-medium text-slate-700 dark:text-zinc-300 whitespace-nowrap">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          <time {...(item.datetime ? { datetime: item.datetime } : {})}>
            {item.period}
          </time>
        </div>
        
        {isPresent && (
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-xs font-semibold bg-gradient-to-r from-emerald-500 to-teal-500 dark:from-emerald-400 dark:to-teal-400 text-white dark:text-zinc-900 shadow-md animate-pulse-slow whitespace-nowrap">
            <span class="relative flex h-2 w-2 shrink-0">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
            </span>
            Current
          </span>
        )}
      </div>
    </div>

    <!-- Responsibilities - Better spacing -->
    {item.bullets?.length > 0 && (
      <ul class="space-y-4">
        {item.bullets.map((b) => (
          <li class="flex gap-4 group/item">
            <!-- Icon with gradient background -->
            <span class="mt-1 flex items-center justify-center h-6 w-6 lg:h-7 lg:w-7 shrink-0 rounded-lg bg-gradient-to-br from-indigo-100 to-purple-100 dark:from-indigo-950/50 dark:to-purple-950/50 border border-indigo-200/50 dark:border-indigo-800/50 group-hover/item:scale-110 group-hover/item:rotate-3 transition-all duration-300" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 lg:h-4 lg:w-4 text-indigo-600 dark:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M5 12l5 5L20 7"/>
              </svg>
            </span>
            
            <span class="flex-1 text-sm lg:text-base leading-relaxed text-slate-700 dark:text-zinc-300 group-hover/item:text-slate-900 dark:group-hover/item:text-zinc-100 transition-colors">
              {b}
            </span>
          </li>
        ))}
      </ul>
    )}
  </div>

  <!-- Hover ring effect -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 rounded-3xl ring-0 group-hover:ring-1 ring-indigo-200/60 dark:ring-indigo-500/20 transition-all duration-500"></div>

  <!-- Decorative corner accent -->
  <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-indigo-500/5 to-purple-500/5 dark:from-indigo-500/10 dark:to-purple-500/10 rounded-bl-[4rem] opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" aria-hidden="true"></div>
</article>
---
interface Props {
  name: string;
  role: string;
  location: string;
  avatar: string; // dark image (cropped)
  centered?: boolean; // avatar-only centered mode for hero
}

const { name, role, location, avatar, centered = false } = Astro.props as Props;

const avatarLight = "/profiles/carlos_light.png";
const avatarDarkFull = "/profiles/carlos_dark_fullsize.png";
const avatarLightFull = "/profiles/carlos_light_fullsize.png";
const avatarDarkShy = "/profiles/carlos_dark_shy.png";
const avatarLightShy = "/profiles/carlos_light_shy.png";
const avatarDarkFullShy = "/profiles/carlos_dark_fullsize_shy.png";
const avatarLightFullShy = "/profiles/carlos_light_fullsize_shy.png";

// Lottie hint (place these JSONs in /public/animation/)
const hintLight = "/animation/click_light.json";
const hintDark  = "/animation/click_dark.json";
---

<article class={centered ? "mt-6 flex flex-col items-center" : "mt-4 sm:mt-6 flex items-center gap-4 sm:gap-6 flex-nowrap"}>
  <!-- Avatar wrapper is relative so we can position the hint -->
  <div class="relative">
    <!-- Glass gradient border wrap — always present, styled only in centered mode -->
    <div class={centered
      ? "p-[3px] rounded-2xl bg-gradient-to-br from-white/40 via-indigo-400/50 to-purple-500/50 dark:from-white/20 dark:via-indigo-500/40 dark:to-purple-500/40 shadow-[0_0_32px_rgba(99,102,241,0.35)] dark:shadow-[0_0_48px_rgba(99,102,241,0.5)]"
      : ""}>
    <!-- Avatar stack (two layers for smooth crossfade) -->
    <div
      id="profile-avatar"
      role="img"
      aria-label={`Portrait of ${name}`}
      class={centered
        ? "relative h-36 w-36 sm:h-40 sm:w-40 rounded-2xl overflow-hidden cursor-pointer shadow-lg flex-shrink-0 transition-transform duration-300 hover:scale-[1.02]"
        : "relative h-28 w-28 sm:h-32 sm:w-32 rounded-2xl overflow-hidden cursor-pointer ring-2 ring-indigo-400/40 dark:ring-sky-500/30 shadow-lg flex-shrink-0 transition-transform duration-300 hover:scale-[1.02]"}
      data-dark={avatar}
      data-light={avatarLight}
      data-dark-full={avatarDarkFull}
      data-light-full={avatarLightFull}
      data-dark-shy={avatarDarkShy}
      data-light-shy={avatarLightShy}
      data-dark-full-shy={avatarDarkFullShy}
      data-light-full-shy={avatarLightFullShy}
    >
      <!-- Layer A (starts active) -->
      <img
        id="profile-layer-a"
        src={avatar}
        alt={`Portrait of ${name}`}
        width="140"
        height="140"
        class="absolute inset-0 w-full h-full object-cover"
        style="transition: opacity 500ms ease;"
        loading="eager"
        decoding="async"
      />
      <!-- Layer B (starts hidden) -->
      <img
        id="profile-layer-b"
        src={avatar}
        alt=""
        aria-hidden="true"
        width="140"
        height="140"
        class="absolute inset-0 w-full h-full object-cover"
        style="transition: opacity 500ms ease; opacity: 0;"
        loading="eager"
        decoding="async"
      />
    </div>
    </div><!-- /glass gradient border wrap -->

    <!-- Click hint (Lottie target). Pointer-events none so clicks go to the avatar -->
    <div
      id="click-hint"
      class="pointer-events-none absolute bottom-0 right-0 translate-x-[40%] translate-y-[40%]
             h-16 w-16 opacity-0 z-10"
      data-light={hintLight}
      data-dark={hintDark}
      aria-hidden="true"
    ></div>
  </div>

  <!-- Info (hidden in centered/hero mode) -->
  {!centered && <div class="min-w-0 flex-1">
    <h2 class="text-base sm:text-xl font-semibold text-slate-900 dark:text-zinc-100 leading-tight">
      {name}
    </h2>

    <p class="mt-0.5 flex items-center gap-1 text-[0.75rem] sm:text-sm text-slate-600 dark:text-zinc-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 sm:h-4 sm:w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7Zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Z"/>
      </svg>
      <span class="truncate">{location}</span>
    </p>

    <p class="mt-0.5 flex items-center gap-1 text-xs sm:text-base text-slate-700 dark:text-zinc-300 leading-snug">
  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 sm:h-4 sm:w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
    <path d="M10 2a1 1 0 0 0-1 1v2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-3V3a1 1 0 0 0-1-1h-4Zm1 3V4h2v1h-2Z"/>
  </svg>
  <span>{role}</span>
</p>

  </div>}
</article>

<!-- Modal is created and appended to body via JS below -->

<!-- Scripts -->
<script is:inline>
  const wrap = document.getElementById("profile-avatar");
  const layerA = document.getElementById("profile-layer-a");
  const layerB = document.getElementById("profile-layer-b");
  const hint = document.getElementById("click-hint");

  // Hoisted so closeBtn listener can call it before bind() runs
  var closeModal = function() {};

  // ---- Build modal overlay and append to <body> ----
  var overlay = document.createElement("div");
  overlay.style.cssText = [
    "position:fixed", "top:0", "left:0", "width:100%", "height:100%",
    "z-index:99999", "background:rgba(0,0,0,0.8)", "backdrop-filter:blur(10px)",
    "-webkit-backdrop-filter:blur(10px)", "display:none",
    "align-items:center", "justify-content:center",
    "opacity:0", "transition:opacity 0.3s ease", "cursor:pointer"
  ].join(";");

  var modalImg = document.createElement("img");
  modalImg.alt = "Full-size portrait";
  modalImg.style.cssText = [
    "max-height:90vh", "max-width:90vw", "border-radius:1rem",
    "object-fit:contain", "box-shadow:0 25px 60px rgba(0,0,0,0.5)",
    "cursor:default", "transition:transform 0.3s ease", "transform:scale(0.95)"
  ].join(";");

  // Clicks on the image must NOT close the modal
  modalImg.addEventListener("click", function(e) { e.stopPropagation(); });

  // Close button — top-right corner
  var closeBtn = document.createElement("button");
  closeBtn.setAttribute("aria-label", "Close");
  closeBtn.style.cssText = [
    "position:absolute", "top:16px", "right:16px",
    "width:40px", "height:40px", "border-radius:50%",
    "background:rgba(255,255,255,0.15)", "backdrop-filter:blur(6px)",
    "-webkit-backdrop-filter:blur(6px)",
    "border:1px solid rgba(255,255,255,0.25)",
    "color:#fff", "font-size:18px", "line-height:1",
    "display:flex", "align-items:center", "justify-content:center",
    "cursor:pointer", "transition:background 0.2s ease",
    "z-index:1"
  ].join(";");
  closeBtn.innerHTML = "&#x2715;"; // ✕
  closeBtn.addEventListener("mouseenter", function() {
    closeBtn.style.background = "rgba(255,255,255,0.28)";
  });
  closeBtn.addEventListener("mouseleave", function() {
    closeBtn.style.background = "rgba(255,255,255,0.15)";
  });
  closeBtn.addEventListener("click", function(e) {
    e.stopPropagation();
    closeModal();
  });

  overlay.appendChild(modalImg);
  overlay.appendChild(closeBtn);
  document.body.appendChild(overlay);

  // ---- Two-layer crossfade ----
  let activeLayer = 'a'; // 'a' or 'b'

  function crossfadeTo(src) {
    if (!layerA || !layerB) return;
    const incoming = activeLayer === 'a' ? layerB : layerA;
    const outgoing = activeLayer === 'a' ? layerA : layerB;
    incoming.src = src;
    incoming.style.opacity = '1';
    outgoing.style.opacity = '0';
    activeLayer = activeLayer === 'a' ? 'b' : 'a';
  }

  // ---- Theme-aware avatar ----
  function setAvatar() {
    if (!wrap) return;
    const isDark = document.documentElement.classList.contains("dark");
    crossfadeTo(isDark ? wrap.dataset.dark : wrap.dataset.light);
  }

  // ---- Lottie hint loader (theme-aware, stays until clicked) ----
  let lottieInstance = null;

  function hideHint(markSeen = true) {
    if (!hint) return;
    hint.style.opacity = "0";
    setTimeout(() => {
      lottieInstance?.destroy();
      hint.innerHTML = "";
    }, 250);
    if (markSeen) {
      sessionStorage.setItem("kc_click_hint_seen", "1");
    }
  }

  function loadScriptOnce(src) {
    if (window.lottie) return Promise.resolve(window.lottie);
    return new Promise((resolve, reject) => {
      const s = document.createElement("script");
      s.src = src;
      s.async = true;
      s.onload = () => resolve(window.lottie);
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  async function showHintOnce() {
    if (!hint) return;

    // only show once per session; change to localStorage for persistence across tabs
    //if (sessionStorage.getItem("kc_click_hint_seen") === "1") return;

    const isDark = document.documentElement.classList.contains("dark");
    const json = isDark ? hint.dataset.dark : hint.dataset.light;

    try {
      const lottie = await loadScriptOnce("https://unpkg.com/lottie-web@5.12.2/build/player/lottie.min.js");

      // Clean any previous
      hint.innerHTML = "";
      lottieInstance?.destroy();

      lottieInstance = lottie.loadAnimation({
        container: hint,
        renderer: "svg",
        loop: true,
        autoplay: true,
        path: json
      });

      // gentle fade in (no auto-hide)
      hint.style.transition = "opacity 300ms ease";
      requestAnimationFrame(() => { hint.style.opacity = "1"; });
    } catch {
      // if lottie fails, just skip gracefully
    }
  }

  // ---- Wire up events ----

  function preloadImages() {
    if (!wrap) return;
    [
      wrap.dataset.dark, wrap.dataset.light,
      wrap.dataset.darkFull, wrap.dataset.lightFull,
      wrap.dataset.darkShy, wrap.dataset.lightShy,
      wrap.dataset.darkFullShy, wrap.dataset.lightFullShy,
    ]
      .filter(Boolean)
      .forEach(src => { new Image().src = src; });
  }

  function getShy() {
    const isDark = document.documentElement.classList.contains("dark");
    return isDark ? wrap.dataset.darkShy : wrap.dataset.lightShy;
  }

  function getShyFull() {
    const isDark = document.documentElement.classList.contains("dark");
    return isDark ? wrap.dataset.darkFullShy : wrap.dataset.lightFullShy;
  }

  function getNormalFull() {
    const isDark = document.documentElement.classList.contains("dark");
    return isDark ? wrap.dataset.darkFull : wrap.dataset.lightFull;
  }

  // ---- Mobile auto-cycle (touch devices only) ----
  const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
  let cycleHandle = null;

  function rand(min, max) {
    return Math.floor(min + Math.random() * (max - min));
  }

  function stopCycle() {
    clearTimeout(cycleHandle);
    cycleHandle = null;
  }

  function scheduleCycle() {
    if (!isTouchDevice || !wrap) return;
    // Hold normal image for 3–5s, then briefly show shy
    cycleHandle = setTimeout(() => {
      if (document.hidden) { scheduleCycle(); return; }
      crossfadeTo(getShy());
      // Hold shy for 1.8–2.5s, then fade back to normal
      cycleHandle = setTimeout(() => {
        if (document.hidden) { setAvatar(); scheduleCycle(); return; }
        const isDark = document.documentElement.classList.contains("dark");
        crossfadeTo(isDark ? wrap.dataset.dark : wrap.dataset.light);
        scheduleCycle();
      }, rand(1800, 2500));
    }, rand(3000, 5000));
  }

  function bind() {
    preloadImages();
    setAvatar();
    showHintOnce();

    window.addEventListener("themechange", () => {
      stopCycle();
      setAvatar();
      showHintOnce();
      if (isTouchDevice) scheduleCycle();
    });

    window.addEventListener("astro:page-load", () => {
      setAvatar();
      if (!sessionStorage.getItem("kc_click_hint_seen")) showHintOnce();
    });

    // Pause cycle when tab is hidden, resume when visible
    document.addEventListener("visibilitychange", () => {
      if (!isTouchDevice) return;
      if (document.hidden) {
        stopCycle();
      } else {
        setAvatar();
        scheduleCycle();
      }
    });

    if (isTouchDevice) {
      // Mobile: start ambient crossfade cycle
      scheduleCycle();
    } else {
      // Desktop only: hover → shy
      wrap?.addEventListener("mouseenter", () => crossfadeTo(getShy()));
      wrap?.addEventListener("mouseleave", () => setAvatar());
    }

    // ---- Modal open / close ----
    function openModal() {
      var isDark = document.documentElement.classList.contains("dark");
      modalImg.src = isDark ? wrap.dataset.darkFull : wrap.dataset.lightFull;
      modalImg.style.transform = "scale(0.95)";
      overlay.style.display = "flex";
      // Double rAF ensures display:flex is painted before opacity transitions
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          overlay.style.opacity = "1";
          modalImg.style.transform = "scale(1)";
        });
      });
    }

    closeModal = function() {
      overlay.style.opacity = "0";
      modalImg.style.transform = "scale(0.95)";
      setTimeout(function() { overlay.style.display = "none"; }, 300);
      if (isTouchDevice) scheduleCycle();
    };

    // Open on avatar click
    wrap?.addEventListener("click", function() {
      stopCycle();
      hideHint(false);
      openModal();
    });

    // Modal image hover → shy fullsize (desktop only)
    if (!isTouchDevice) {
      modalImg.addEventListener("mouseenter", function() {
        var isDark = document.documentElement.classList.contains("dark");
        modalImg.src = isDark ? wrap.dataset.darkFullShy : wrap.dataset.lightFullShy;
      });
      modalImg.addEventListener("mouseleave", function() {
        var isDark = document.documentElement.classList.contains("dark");
        modalImg.src = isDark ? wrap.dataset.darkFull : wrap.dataset.lightFull;
      });
    }

    // Close when clicking the backdrop (overlay itself, not the image — image stops propagation)
    overlay.addEventListener("click", closeModal);

    // Close on Esc
    document.addEventListener("keydown", function(e) { if (e.key === "Escape") closeModal(); });
  }

  bind();
</script>

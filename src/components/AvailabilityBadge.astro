---
interface Props {
  text?: string;
}

const { text = "Available for remote work" } = Astro.props as Props;
---

<div
  class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm font-medium
         bg-white/70 border-indigo-200 text-indigo-700
         dark:bg-zinc-900/70 dark:border-indigo-900/50 dark:text-indigo-300
         shadow-sm ring-1 ring-slate-200/60 dark:ring-zinc-800 backdrop-blur"
  role="status"
  aria-live="polite"
>
  <!-- Animated availability dot -->
  <span class="relative inline-flex h-2.5 w-2.5 items-center justify-center">
    <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400/40 animate-ping motion-reduce:animate-none"></span>
    <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500 dark:bg-emerald-400"></span>
  </span>

  <span class="tracking-tight">{text}</span>
</div>

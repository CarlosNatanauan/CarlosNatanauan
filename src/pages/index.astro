---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ExperienceItem from "../components/ExperienceItem.astro";
import { projects } from "../data/projects.js";
import { experience } from "../data/experience.js";
import ContactForm from "../components/ContactForm.astro";
import ProfileCard from "../components/ProfileCard.astro";
import AvailabilityBadge from "../components/AvailabilityBadge.astro";
import { profile } from "../data/profile.js";


const NAME = "Carlos";
const TAGLINE = "Software Developer crafting apps that don't just run, but (most of the time) actually work.";
const EMAIL = "carlosbenedictn@gmail.com";

const LINKS = {
  github: "https://github.com/CarlosNatanauan",
  linkedin: "https://www.linkedin.com/in/carlosnatanauan/",
  email: `mailto:${EMAIL}?subject=${encodeURIComponent("Hello Carlos")}`,
};
---
<BaseLayout title="Kuya Carlos">

<!-- Hero -->
<section class="pt-10 pb-14 sm:pt-14 sm:pb-20">
  <div class="flex items-center gap-3">
    <AvailabilityBadge />
  </div>

  <ProfileCard
    name={profile.name}
    role={profile.role}
    location={profile.location}
    avatar={profile.avatar}
  />

  <!-- Typing Effect Heading -->
  <h1 class="mt-4 text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-tight">
    <span class="text-slate-800/95 dark:text-zinc-100/95">Hello, I'm</span>{" "}
    <span id="typed-name" class="align-baseline metal-gradient animate-gradient drop-shadow-[0_1px_0_rgba(255,255,255,0.65)]" aria-live="polite">
      Carlos
    </span>
    <span id="typed-cursor" class="ml-1 inline-block w-[0.6ch] select-none">|</span>
  </h1>

  <!-- Typing Script (keep your existing script) -->
  <script is:inline>
    const WORDS = ["Carlos", "Batman"];
    const el = document.getElementById("typed-name");
    const cursor = document.getElementById("typed-cursor");

    const TYPE_MS = 90;
    const DELETE_MS = 55;
    const HOLD_MS = 1100;
    const LOOP_PAUSE_MS = 400;

    let wi = 0, ci = 0, deleting = false;

    function applyTheme(word) {
      if (word === "Carlos") {
        el.classList.remove("metal-gradient");
        el.classList.add("neon-gradient");
        cursor.style.color = "rgb(56 189 248)";
      } else {
        el.classList.remove("neon-gradient");
        el.classList.add("metal-gradient");
        cursor.style.color = "rgb(24 24 27)";
      }
    }

    function step() {
      const word = WORDS[wi];
      applyTheme(word);

      if (!deleting) {
        ci++;
        el.textContent = word.slice(0, ci);
        if (ci === word.length) return setTimeout(() => { deleting = true; step(); }, HOLD_MS);
      } else {
        ci--;
        el.textContent = word.slice(0, ci);
        if (ci === 0) { wi = (wi + 1) % WORDS.length; deleting = false; return setTimeout(step, LOOP_PAUSE_MS); }
      }
      setTimeout(step, deleting ? DELETE_MS : TYPE_MS);
    }

    function blink() { cursor.style.opacity = cursor.style.opacity === "0" ? "1" : "0"; }
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!prefersReduced) { setInterval(blink, 500); setTimeout(step, 300); }
    else { cursor.style.display = "none"; el.textContent = WORDS[0]; applyTheme(WORDS[0]); }
  </script>

  <!-- Bio Section with subtle highlights -->
  <div class="mt-6 space-y-3 max-w-2xl">
    <p class="text-base sm:text-lg leading-relaxed text-slate-600 dark:text-zinc-400">
      I'm a software developer with a BSIT degree from
      <span class="font-medium text-slate-700 dark:text-zinc-300">STI College</span>,
      where I built my foundation in
      <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-slate-100 dark:bg-zinc-800 text-slate-700 dark:text-zinc-300 text-sm font-medium">C#</span>
      <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-slate-100 dark:bg-zinc-800 text-slate-700 dark:text-zinc-300 text-sm font-medium">.NET</span>
      and
      <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-slate-100 dark:bg-zinc-800 text-slate-700 dark:text-zinc-300 text-sm font-medium">SQL</span>.
      Since then, I've specialized in
      <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-slate-100 dark:bg-zinc-800 text-slate-700 dark:text-zinc-300 text-sm font-medium">Flutter</span>
      development and backend API integrations, building mobile apps that hold up in production —
      <span class="font-medium text-slate-700 dark:text-zinc-300">not just in demos</span>.
      I've worked on and maintain production mobile apps currently live on the
      <span class="font-medium text-slate-700 dark:text-zinc-300">App Store and Google Play</span>.
    </p>

    <p class="text-base sm:text-lg leading-relaxed text-slate-600 dark:text-zinc-400">
      I care about
      <span class="font-medium text-indigo-600 dark:text-indigo-400">clean architecture</span>,
      <span class="font-medium text-indigo-600 dark:text-indigo-400">thoughtful UX</span>,
      and writing code that still makes sense a month later. When I'm not building, I'm usually picking up something new,
      chipping away at a side project, going for a run, or convincing myself that one more coffee is a productivity strategy.
    </p>
  </div>

  <!-- Compact CTA + Social Icons -->
  <div class="mt-7 flex flex-wrap items-center gap-3">
    <!-- Smaller Primary CTA -->
    <a 
      href="#contact" 
      class="group inline-flex items-center justify-center gap-2 rounded-lg 
             bg-gradient-to-r from-indigo-600 to-purple-600 
             hover:from-indigo-500 hover:to-purple-500
             dark:from-indigo-500 dark:to-purple-500
             dark:hover:from-indigo-400 dark:hover:to-purple-400
             text-white px-5 py-2.5 text-sm font-medium 
             shadow-md hover:shadow-lg
             transition-all duration-300 hover:scale-105 active:scale-95"
    >
      <span>Let's Talk</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Compact Social Links -->
    <div class="flex items-center gap-2">
      <!-- GitHub -->
      <a 
        href={LINKS.github} 
        target="_blank" 
        rel="noreferrer"
        class="group flex items-center justify-center w-10 h-10 rounded-lg 
               border border-slate-300 dark:border-zinc-700 
               bg-white dark:bg-zinc-900
               hover:bg-slate-50 dark:hover:bg-zinc-800 
               hover:border-slate-400 dark:hover:border-zinc-600
               hover:scale-110 active:scale-95
               transition-all duration-200 shadow-sm hover:shadow"
        aria-label="GitHub"
        title="GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5 text-slate-700 dark:text-zinc-300" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .5a11.5 11.5 0 0 0-3.64 22.4c.58.1.8-.25.8-.56v-2c-3.26.71-3.95-1.57-3.95-1.57-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.8 2.72 1.28 3.38.98.1-.76.41-1.28.75-1.58-2.6-.29-5.34-1.3-5.34-5.8 0-1.28.46-2.33 1.2-3.15-.12-.3-.52-1.52.12-3.17 0 0 .98-.31 3.2 1.2a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.2 3.2-1.2.64 1.65.24 2.87.12 3.17.75.82 1.2 1.87 1.2 3.15 0 4.5-2.75 5.51-5.36 5.8.43.37.81 1.1.81 2.22v3.3c0 .31.21.67.81.56A11.5 11.5 0 0 0 12 .5z"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a 
        href={LINKS.linkedin} 
        target="_blank" 
        rel="noreferrer"
        class="group flex items-center justify-center w-10 h-10 rounded-lg 
               border border-slate-300 dark:border-zinc-700 
               bg-white dark:bg-zinc-900
               hover:bg-slate-50 dark:hover:bg-zinc-800 
               hover:border-slate-400 dark:hover:border-zinc-600
               hover:scale-110 active:scale-95
               transition-all duration-200 shadow-sm hover:shadow"
        aria-label="LinkedIn"
        title="LinkedIn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5 text-slate-700 dark:text-zinc-300" viewBox="0 0 24 24" fill="currentColor">
          <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 8.98h3.96V21H3zM9.5 8.98H13v1.63h.05c.49-.93 1.68-1.9 3.46-1.9 3.7 0 4.38 2.43 4.38 5.6V21h-3.96v-5.35c0-1.28-.02-2.93-1.79-2.93-1.8 0-2.07 1.4-2.07 2.84V21H9.5z"/>
        </svg>
      </a>

      <!-- Email -->
      <a 
        href={LINKS.email}
        class="group flex items-center justify-center w-10 h-10 rounded-lg 
               border border-slate-300 dark:border-zinc-700 
               bg-white dark:bg-zinc-900
               hover:bg-slate-50 dark:hover:bg-zinc-800 
               hover:border-slate-400 dark:hover:border-zinc-600
               hover:scale-110 active:scale-95
               transition-all duration-200 shadow-sm hover:shadow"
        aria-label="Email"
        title="Email"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5 text-slate-700 dark:text-zinc-300" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4-8 5L4 8V6l8 5 8-5z"/>
        </svg>
      </a>
    </div>
  </div>
</section>



  <!-- Projects -->
<section id="projects" class="scroll-mt-28 md:scroll-mt-24 mt-20">
  <!-- Section Header with Animation -->
  <div class="text-center mb-12">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full 
                bg-indigo-50 dark:bg-indigo-950/50 
                border border-indigo-200 dark:border-indigo-900
                text-indigo-600 dark:text-indigo-400 text-sm font-medium mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="3" width="20" height="14" rx="2"/>
        <path d="M8 21h8M12 17v4"/>
      </svg>
      Featured Work
    </div>
    
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight
               bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900
               dark:from-zinc-100 dark:via-zinc-200 dark:to-zinc-100
               bg-clip-text text-transparent mb-4">
      Projects
    </h2>
    
    <p class="text-lg text-slate-600 dark:text-zinc-400 max-w-2xl mx-auto">
      A collection of projects I've built — from full-stack applications to mobile experiences
    </p>
  </div>

  <!-- Projects Grid - Responsive with better layout -->
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 auto-rows-fr">
    {projects.map((p, index) => (
      <div 
        class="animate-fade-in-up"
        style={`animation-delay: ${index * 100}ms`}
      >
        <ProjectCard project={p} />
      </div>
    ))}
  </div>

  <!-- Optional: View More Button -->
  <div class="mt-12 text-center">
    <a
      href="https://github.com/CarlosNatanauan"
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-xl
             bg-slate-100 dark:bg-zinc-800
             hover:bg-slate-200 dark:hover:bg-zinc-700
             border border-slate-300 dark:border-zinc-700
             text-slate-700 dark:text-zinc-300
             font-medium transition-all duration-300
             hover:scale-105 active:scale-95 hover:shadow-lg"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .5a11.5 11.5 0 0 0-3.64 22.4c.58.1.8-.25.8-.56v-2c-3.26.71-3.95-1.57-3.95-1.57-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.8 2.72 1.28 3.38.98.1-.76.41-1.28.75-1.58-2.6-.29-5.34-1.3-5.34-5.8 0-1.28.46-2.33 1.2-3.15-.12-.3-.52-1.52.12-3.17 0 0 .98-.31 3.2 1.2a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.2 3.2-1.2.64 1.65.24 2.87.12 3.17.75.82 1.2 1.87 1.2 3.15 0 4.5-2.75 5.51-5.36 5.8.43.37.81 1.1.81 2.22v3.3c0 .31.21.67.81.56A11.5 11.5 0 0 0 12 .5z"/>
      </svg>
      View More on GitHub
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</section>


<!-- Experience Section -->
<section id="experience" class="scroll-mt-28 md:scroll-mt-24 mt-20">
  <!-- Section Header with Animation -->
  <div class="text-center mb-12 lg:mb-16">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-purple-50 dark:bg-purple-950/50 border border-purple-200 dark:border-purple-900 text-purple-600 dark:text-purple-400 text-sm font-medium mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 7h-9M14 17H5M6 3v4M10 17v4M14 7v10"/>
      </svg>
      Career Journey
    </div>
    
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 dark:from-zinc-100 dark:via-zinc-200 dark:to-zinc-100 bg-clip-text text-transparent mb-4">
      Experience
    </h2>
    
    <p class="text-lg text-slate-600 dark:text-zinc-400 max-w-2xl mx-auto">
      Roles and internships where I learned, built, and shipped real products
    </p>
  </div>

  <!-- Simple stacked layout - no complex timeline on large screens -->
  <div class="max-w-4xl mx-auto space-y-8 lg:space-y-10">
    {experience.map((item, index) => (
      <div class="animate-fade-in-up" style={`animation-delay: ${index * 150}ms`}>
        <ExperienceItem item={item} />
      </div>
    ))}
  </div>

<!--
  <div class="mt-16 text-center">
    <a href="/resume.pdf" download class="inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 dark:from-indigo-500 dark:to-purple-500 dark:hover:from-indigo-400 dark:hover:to-purple-400 text-white text-base font-medium shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105 active:scale-95">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/>
      </svg>
      Download Resume
    </a>
  </div>
-->

  
</section>




  <!-- Contact -->
  <section id="contact" class="scroll-mt-28 md:scroll-mt-24">
    <SectionTitle>Contact</SectionTitle>
    <ContactForm
      action="https://formspree.io/f/mldekgro"
      subject="New portfolio message!"
      title="Contact"
    />
  </section>
</BaseLayout>
